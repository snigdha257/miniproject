# Backend Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Secret key for signing JWT tokens (use a long random string in production)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET

# Token algorithm
JWT_ALGORITHM=HS256

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Fernet encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=CHANGE_ME_TO_A_FERNET_KEY

# Application environment (development | production)
APP_ENV=development
